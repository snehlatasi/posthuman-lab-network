# ==========================================
# POSTHUMAN LAB NETWORK - ENVIRONMENT CONFIG
# ==========================================

# --- BACKEND (SPRING BOOT) ---
# The port the backend server will listen on
PORT=8080

# H2 File Database connection settings
DB_PATH=./data/posthuman_db
DB_USER=sa
DB_PASS=your_secure_password_here
H2_CONSOLE_ENABLED=true

# --- FRONTEND (NEXT.JS) ---
# Next.js Port
FRONTEND_PORT=3000

# Base URL for API requests (Next.js client-side requests)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
